name: Generate Studio Assets

on:
  workflow_dispatch:
  push:
    paths:
      - "generate_studio_assets.py"
      - "claim_audit/claim_map_v4.json"
      - "CLAIMS.md"
      - "README.md"

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - run: python generate_studio_assets.py
      - name: Commit changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add studio_assets
          git diff --cached --quiet || git commit -m "Auto-generate studio assets"
          git push
